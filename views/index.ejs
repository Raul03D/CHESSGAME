<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium Chess</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .chessboard {
            display: grid;
            grid-template-columns: repeat(8, minmax(0, 1fr));
            grid-template-rows: repeat(8, minmax(0, 1fr));
            width: min(90vw, 600px);
            height: min(90vw, 600px);
            transform: rotate(0deg);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            border: 4px solid #334155;
            border-radius: 4px;
            overflow: hidden;
            transition: transform 0.5s ease;
        }

        .square {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .square.light {
            background-color: #ebecd0;
        }

        .square.dark {
            background-color: #739552;
        }

        .piece {
            width: 85%;
            height: 85%;
            cursor: pointer;
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            transition: transform 0.1s ease-in-out;
            filter: drop-shadow(0 4px 4px rgba(0,0,0,0.4));
        }
        
        .piece:hover {
            transform: scale(1.1);
        }

        .piece.draggable {
            cursor: grab;
        }
        
        .piece.draggable:active {
            cursor: grabbing;
            transform: scale(1.15);
        }

        .dragging {
            opacity: 0.5;
        }

        /* Rotate pieces for black player */
        .flipped {
            transform: rotate(180deg);
        }

        .flipped .piece {
            transform: rotate(180deg);
        }
        
        .flipped .piece:hover {
            transform: rotate(180deg) scale(1.1);
        }
        
        .flipped .piece.draggable:active {
            transform: rotate(180deg) scale(1.15);
        }
    </style> 
</head>
<body class="bg-slate-900 text-slate-200 h-screen flex flex-col items-center justify-center p-4">
    
    <div class="mb-6 flex flex-col items-center">
        <h1 class="text-4xl font-bold bg-gradient-to-r from-teal-400 to-emerald-400 bg-clip-text text-transparent drop-shadow-sm mb-2">Grandmaster Chess</h1>
        <div id="player-role" class="text-sm font-semibold px-4 py-1 rounded-full bg-slate-800 border border-slate-700 shadow-inner flex items-center gap-2 transition-colors duration-300">
            <span class="w-2 h-2 rounded-full bg-yellow-500 animate-pulse"></span>
            Waiting for opponent...
        </div>
    </div>

    <div class="relative bg-slate-800/50 p-6 rounded-2xl backdrop-blur-md border border-slate-700/50 shadow-2xl">
        <div class="chessboard"></div>
    </div>

    <div class="mt-8 text-xs text-slate-500 font-medium tracking-wider uppercase flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        Live Server Connected
    </div>

    <script src="https://cdn.socket.io/4.8.3/socket.io.min.js" integrity="sha384-kzavj5fiMwLKzzD1f8S7TeoVIEi7uKHvbTA3ueZkrzYq75pNQUiUi6Dy98Q3fxb0" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js" integrity="sha512-xRllwz2gdZciIB+AkEbeq+gVhX8VB8XsfqeFbUh+SzHlN96dEduwtTuVuc2u9EROlmW9+yhRlxjif66ORpsgVA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="/js/chessgame.js"></script>
    
</body> 
</html>